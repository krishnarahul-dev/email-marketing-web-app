# ============================================================
# MailForge — Environment Variables
# Copy this file to .env and fill in all values
# ============================================================

# ─── General ────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ─── PostgreSQL ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=emailtool
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_POOL_MAX=20

# ─── Redis ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_with_command_above
JWT_EXPIRES_IN=7d
UNSUBSCRIBE_SECRET=CHANGE_ME_generate_a_different_one

# ─── Amazon SES ─────────────────────────────────────────────
SES_REGION=us-east-1
SES_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXXXX
SES_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SES_CONFIGURATION_SET=email-tool-tracking

# ─── Postmark (Inbound Emails) ──────────────────────────────
POSTMARK_WEBHOOK_TOKEN=

# ─── Claude AI (Tone Detection) ─────────────────────────────
CLAUDE_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Email Sending Limits ───────────────────────────────────
EMAIL_MAX_BATCH_SIZE=50
EMAIL_RATE_LIMIT_PER_SECOND=14
EMAIL_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY_MS=5000
